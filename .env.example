# Frontend (safe in Vercel “Environment Variables” for Production — these are public in the bundle)
VITE_RECAPTCHA_SITE_KEY=
VITE_RECAPTCHA_SIZE=checkbox

# Worker URL only (no /api). Required on Vercel so /demo and /embed call your deployed API.
# Example: https://voice-captcha-api.your-subdomain.workers.dev
VITE_API_BASE_URL=

# Groq + ElevenLabs are NOT configured here. They live only on the Cloudflare Worker
# (wrangler secret / dashboard). See DEPLOY.md.
