# Frontend (safe in Vercel — public in the bundle). Create keys: https://www.google.com/recaptcha/admin
# reCAPTCHA v2 “I’m not a robot” (or Invisible). Register localhost + your production domain(s).
# Leave empty locally to use Google’s test key only in `npm run dev`.
VITE_RECAPTCHA_SITE_KEY=
VITE_RECAPTCHA_SIZE=checkbox

# Worker URL only (no /api). Required on Vercel so /demo and /embed call your deployed API.
# Hosted API (this project): https://voice-captcha-api.rashmie30.workers.dev
VITE_API_BASE_URL=

# Groq + ElevenLabs are NOT configured here. They live only on the Cloudflare Worker
# (wrangler secret / dashboard). See DEPLOY.md.
